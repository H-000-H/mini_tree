# mini_tree Kconfig (STM32F407ZGT6)
# Edit mini_tree/.config or run tools/menuconfig.py

menu "mini_tree Configuration"

menu "Platform"
choice
    prompt "Target MCU"
    default PLATFORM_ARM_CM4F
    help
      Select the target processor architecture.

config PLATFORM_ARM_CM7
    bool "ARM Cortex-M7"

config PLATFORM_ARM_CM4F
    bool "ARM Cortex-M4F"

config PLATFORM_ARM_CM3
    bool "ARM Cortex-M3"

config PLATFORM_RISCV
    bool "RISC-V (32-bit)"
endchoice
endmenu

menu "Multi-core Configuration"

config CPU_CORES
    int "Number of CPU cores"
    default 1
    range 1 2
    help
      CPU 核心数量。1 = 单核模式（默认）。
      2 = 双核 AMP 模式，Core 0 跑 RTOS，
      Core 1 跑裸机代码。
      设为 2 时板级需实现
      hal_cpu_secondary_startup()。

endmenu

menu "OSAL Backend"
choice
    prompt "RTOS backend"
    default OSAL_NULL
    help
      Select the OS abstraction layer backend.

config OSAL_FREERTOS
    bool "FreeRTOS"
    help
      Use bundled or project-supplied FreeRTOS.

config OSAL_RTTHREAD
    bool "RT-Thread"
    help
      Use RT-Thread kernel as OSAL backend.

config OSAL_NULL
    bool "None (bare-metal)"
    help
      No RTOS. Queue uses ring buffer + busy-wait.
endchoice
endmenu

menu "System Log"
choice
    prompt "Log backend"
    default SYS_LOG_USE_PRINTF
    help
      Select system log output backend.

config SYS_LOG_USE_PRINTF
    bool "Direct printf"
    help
      Output via plain printf.

config SYS_LOG_USE_OSAL
    bool "OSAL logging"
    help
      Output via OSAL log interface.
endchoice
endmenu

menu "System Backend"
choice
    prompt "System runtime implementation"
    default SYSTEM_CPP
    help
      Select C or C++ system backend.

config SYSTEM_C
    bool "C"
    help
      Pure C system runtime.

config SYSTEM_CPP
    bool "C++"
    help
      C++ system runtime.
endchoice
endmenu

menu "Board Features"

config PRODUCTION_LOG
    bool "Production log"
    default n
    help
      Enable production-level logging.

config SAFETY_SHUTDOWN
    bool "Safety shutdown"
    default n
    help
      Enable hardware-level safety shutdown.

config ENABLE_WDT
    bool "Watchdog (IWDG + TWDT)"
    default y
    help
      Enable independent watchdog and task watchdog stubs.

config ENABLE_FLASH_SCRUBBER
    bool "Flash bit-rot scrubber background task"
    default y
    help
      Periodically scan flash and verify CRC baseline.
      Independent of ENABLE_WDT.
endmenu

menu "HAL GPIO"

config HAL_GPIO_PORT_ENUM
    bool "GPIO port enum (GPIOA/B/C for multi-port MCUs)"
    default y
    help
      Enable gpio-port field in device tree for multi-port MCUs (STM32/CH32).
      hal_pin_probe reads port when enabled; port is always 0 on ESP32.

choice HAL_PIN_MAP_MODE
    prompt "Logical pin to HW GPIO encoding"
    default HAL_PIN_MAP_LINEAR
    help
      How hal_pin_map_hw_gpio() encodes hal_pin_t for subsystems
      that need a single integer (e.g. ESP-IDF SPI pin numbers).

config HAL_PIN_MAP_FLAT
    bool "Flat (pin field only, ESP32)"

config HAL_PIN_MAP_LINEAR
    bool "Linear (port << 4 | pin, STM32/CH32)"

endchoice

choice HAL_GPIO_BACKEND
    prompt "GPIO driver backend"
    default HAL_GPIO_STM32
    help
      Platform-specific GPIO implementation linked at build time.

config HAL_GPIO_ESP32
    bool "ESP-IDF gpio driver"

config HAL_GPIO_STM32
    bool "STM32 register GPIO"

config HAL_GPIO_CH32
    bool "CH32 GPIO library"

endchoice

endmenu

menu "Runtime Capacity"

config EVENT_BUS_QUEUE_LEN
    int "Event bus queue depth"
    default 64
    range 8 256

config EVENT_BUS_MAX_SUBSCRIBERS
    int "Event bus max subscribers"
    default 24
    range 4 64

config EVENT_BUS_DISPATCH_STACK
    int "Event bus dispatch task stack (bytes)"
    default 2048
    range 512 8192

config OSAL_MUTEX_POOL_SIZE
    int "OSAL static mutex pool size"
    default 24
    range 4 64

config BOARD_STACK_MONITOR_MAX_TASKS
    int "Stack monitor max registered tasks"
    default 8
    range 1 32

endmenu

menu "Compiler Compatibility"

config COMPILER_GNU_EXTENSIONS
    bool "GNU compiler extensions (container_of, likely/unlikely)"
    default y
    help
      Enable GNU statement expressions and builtins in compiler_compat.h.
      Supported by GCC and Clang.

config COMPILER_WARN_UNUSED_RESULT
    bool "Warn on ignored function results (COMPAT_WARN_UNUSED_RESULT)"
    default y
    depends on COMPILER_GNU_EXTENSIONS
    help
      Annotate critical APIs so the compiler warns when return values
      are discarded. Use COMPAT_IGNORE_RESULT() to silence intentionally.

endmenu

menu "Build Options"

config BUILD_DISASM
    bool "Generate disassembly listing"
    default y
    help
      Generate .lst disassembly listing after build.
      Build-time artifact only; does not affect Flash/RAM usage.
endmenu

endmenu
